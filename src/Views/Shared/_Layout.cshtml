<!DOCTYPE html>
<html lang="de" class="h-full bg-[#fcfbfa] text-[#1e1915]">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Smart Pantry</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="h-full flex flex-col bg-[#fcfbfa]">

    @if (Context.Session.GetInt32("UserID") != null)
    {
        <header class="bg-white/80 backdrop-blur-md border-b border-[#f1eee7] sticky top-0 z-50">
            <div class="max-w-6xl mx-auto px-8 h-20 flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <span class="text-2xl">🍳</span>
                    <span class="text-lg font-extrabold tracking-tight text-[#1e1915] uppercase font-mono">
                        Gusto<span class="text-[#ff5c26]">Pantry</span>
                    </span>
                </div>
                <nav class="flex items-center space-x-8 text-sm font-semibold tracking-wide">
                    <a asp-controller="Pantry" asp-action="Index" 
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Pantry" ? "text-[#1e1915] border-b-2 border-[#ff5c26]" : "text-stone-500 hover:text-[#1e1915]") px-1 py-2 transition-all">
                        Vorratskammer
                    </a>
                    <a asp-controller="Recipe" asp-action="Index" 
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Recipe" ? "text-[#1e1915] border-b-2 border-[#ff5c26]" : "text-stone-500 hover:text-[#1e1915]") px-1 py-2 transition-all">
                        Rezepte
                    </a>
                    <a asp-controller="Account" asp-action="Logout" class="text-stone-400 hover:text-rose-600 px-1 py-2 transition-all">Abmelden</a>
                </nav>
            </div>
        </header>
    }

    <main class="flex-grow max-w-6xl w-full mx-auto px-8 py-16">
        @RenderBody()
    </main>

    <footer class="border-t border-[#f1eee7] text-stone-400 text-xs py-8 text-center tracking-wider font-medium">
        &copy; 2026 — GustoPantry — DanielDegah
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>